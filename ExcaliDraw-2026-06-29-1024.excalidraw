      "link": null,
      "locked": false,
      "text": "Scenario 1 – Claim Amount is ₹50,000",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Scenario 1 – Claim Amount is ₹50,000",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yyVik79H3e8801spgMzno",
      "type": "text",
      "x": -4675.284824944469,
      "y": 506.7498163415621,
      "width": 774.4395751953125,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b11",
      "roundness": null,
      "seed": 1557650545,
      "version": 5,
      "versionNonce": 1387149969,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1782707405649,
      "link": null,
