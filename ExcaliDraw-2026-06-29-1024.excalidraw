    },
    {
      "id": "E6c5oFiRVDJ0Ufy_JvbJn",
      "type": "text",
      "x": -4537.724827385875,
      "y": -55.75018365843789,
      "width": 898.775634765625,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0u",
      "roundness": null,
      "seed": 1476585119,
      "version": 6,
      "versionNonce": 2079451775,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1782707405649,
      "link": null,
      "locked": false,
      "text": "Suppose Mr. Rahul purchased a life insurance policy.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Suppose Mr. Rahul purchased a life insurance policy.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4Zo7ep87FAvLSfBLSmtG-",
      "type": "text",
      "x": -4567.814854241344,
      "y": 14.24981634156211,
      "width": 1007.099609375,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0v",
      "roundness": null,
      "seed": 1258002129,
      "version": 6,
      "versionNonce": 1683439857,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1782707405649,
      "link": null,
      "locked": false,
      "text": "Unfortunately, after a few years, Mr. Rahul passes away.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Unfortunately, after a few years, Mr. Rahul passes away.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dVk1ylvAEx2ypL8zUaiA6",
      "type": "text",
      "x": -4644.824741936656,
      "y": 81.74981634156211,
      "width": 713.5194091796875,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0w",
      "roundness": null,
      "seed": 625654463,
      "version": 5,
      "versionNonce": 544096927,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1782707405649,
      "link": null,
      "locked": false,
      "text": "His wife, Mrs. Priya, is the nominee of\nthe policy. She visits the insurance\ncompany to claim the insurance amount.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "His wife, Mrs. Priya, is the nominee of the policy. She visits the insurance company to claim the insurance amount.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "-s8PtvKYdbNmDi1gez_Ce",
      "type": "text",
      "x": -4675.9747053155625,
      "y": 176.7498163415621,
      "width": 775.8193359375,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0x",
      "roundness": null,
      "seed": 904041649,
      "version": 5,
      "versionNonce": 377748177,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1782707405649,
      "link": null,
      "locked": false,
      "text": "A Claim Assistant receives the request and\ncreates a new insurance claim in the system\nby entering the policy details and\nbeneficiary information.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A Claim Assistant receives the request and creates a new insurance claim in the system by entering the policy details and beneficiary information.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "eC5jHb4HJZCQ-fU2Z7Bpp",
      "type": "text",
