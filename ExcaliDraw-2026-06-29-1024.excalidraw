      "text": "- Claims may be delayed because approvals depend on emails or phone calls.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Claims may be delayed because approvals depend on emails or phone calls.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Qwl2nw-4cByyCQ9FoyaLg",
      "type": "text",
      "x": -4475.614903069469,
      "y": -755.7501836584379,
      "width": 675.1798095703125,
      "height": 45,
      "angle": 0,
